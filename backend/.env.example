# ---- Server ----
PORT=3000

# ---- Blockchain ----
RPC_URL=http://127.0.0.1:8545
SHOP_ADDRESS=0xYOUR_DEPLOYED_TOKENSHOP_ADDRESS

# ---- Database ----
# Replace YOUR_PASSWORD with your PostgreSQL password
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/trolith_studio?schema=public

# ---- Admin ----
# Generate a long random string for production. For local dev, any value works.
ADMIN_API_KEY=change-me-to-a-long-random-string

# ---- Sync ----
# Auto-sync interval in seconds (0 = disabled, use POST /api/sync instead)
SYNC_INTERVAL_SECONDS=15